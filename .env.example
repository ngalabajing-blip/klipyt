# =============================================================================
# Mager Klip — environment configuration
# Copy to .env and fill in real values.
# =============================================================================

# ---- MiMo (Xiaomi) API ----
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic

# Default model IDs (override per call as needed)
MIMO_MODEL_PRO=mimo-v2.5-pro
MIMO_MODEL_FAST=mimo-v2.5
MIMO_MODEL_OMNI=mimo-v2-omni
MIMO_MODEL_TTS=mimo-v2.5-tts
MIMO_MODEL_TTS_CLONE=mimo-v2.5-tts-voiceclone
MIMO_MODEL_TTS_DESIGN=mimo-v2.5-tts-voicedesign

# ---- App ----
APP_ENV=development
APP_SECRET_KEY=change-me-in-prod
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
LOG_LEVEL=INFO

# ---- Database ----
# For dev you can use sqlite: sqlite+aiosqlite:///./mager.db
DATABASE_URL=postgresql+psycopg://mager:mager@localhost:5432/mager

# ---- Redis / queue ----
REDIS_URL=redis://localhost:6379/0

# ---- Storage (S3-compatible) ----
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=mager-klip
S3_PUBLIC_BASE_URL=http://localhost:9000/mager-klip

# ---- Auth ----
# NextAuth requires this on the frontend
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-too

# OAuth providers (optional for MVP)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Social publish (optional) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ---- Whisper ----
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
